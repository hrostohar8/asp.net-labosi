@{
    Layout = "_Layout";
}

@model List<TicketingSystemFightNight.Models.Match>

<nav class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">Početna</a> /
    <span>Mečevi</span>
</nav>

<h2>Pregled - Mečevi</h2>

<div class="entity-grid">
    @foreach (var match in Model)
    {
        <article class="entity-card">
            <h3>@match.Fighter1.Name vs @match.Fighter2.Name</h3>
            <div class="entity-props">
                <p><strong>Id:</strong> @match.Id</p>
                <p><strong>Borac 1:</strong> @match.Fighter1.Name</p>
                <p><strong>Borac 2:</strong> @match.Fighter2.Name</p>
                <p><strong>Težinska klasa:</strong> @match.WeightClass</p>
                <p><strong>Događaj:</strong> @match.Event.Name</p>
                <p><strong>Runde:</strong> @match.RoundLimit</p>
                <p><strong>Šampionski:</strong> @(match.Championship ? "Da" : "Ne")</p>
                <p><strong>Sudac:</strong> @match.Referee</p>
                <p><strong>Status:</strong> @match.Status</p>
            </div>
            <a class="btn" asp-controller="Match" asp-action="Details" asp-route-id="@match.Id">Detalji</a>
        </article>
    }
</div>
