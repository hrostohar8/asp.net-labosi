@{
    Layout = "_Layout";
}

@model TicketingSystemFightNight.Models.Cart

<nav class="breadcrumbs">
    <a asp-controller="Home" asp-action="Index">Početna</a> /
    <a asp-controller="Cart" asp-action="Index">Košarice</a> /
    <span>Detalji</span>
</nav>

<h2>Detalji - Košarica @Model.Id</h2>

<div class="details-container">
    <div class="detail-item">
        <strong>Korisnik:</strong>
        <span>@Model.User.Name</span>
    </div>
    <div class="detail-item">
        <strong>Datum kreiranja:</strong>
        <span>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
    </div>
    <div class="detail-item">
        <strong>Popust kod:</strong>
        <span>@Model.DiscountCode</span>
    </div>
    <div class="detail-item">
        <strong>Popust %:</strong>
        <span>@Model.DiscountPercent%</span>
    </div>
    <div class="detail-item">
        <strong>Plaćeno:</strong>
        <span>@(Model.IsPaid ? "Da" : "Ne")</span>
    </div>
    <div class="detail-item">
        <strong>Ukupna cijena:</strong>
        <span>@Model.TotalPrice.ToString("C")</span>
    </div>

    @if(Model.Tickets != null && Model.Tickets.Any())
    {
        <h3>Karte u košarici</h3>
        <ul>
            @foreach(var ticket in Model.Tickets)
            {
                <li>
                    <a asp-controller="Ticket"
                       asp-action="Details"
                       asp-route-id="@ticket.Id">
                        @ticket.Event.Name - @ticket.Section @ticket.Row@ticket.Seat (@ticket.Price.ToString("C"))
                    </a>
                </li>
            }
        </ul>
    }
</div>

<a asp-controller="Cart" asp-action="Index">Povratak na listu košarica</a>
